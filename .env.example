# Flowra — Environment Variables
# Copy to .env.local and fill in your values. Never commit real secrets.

# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
SESSION_SECRET=

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=

# ── Paystack (payments & invoicing) ───────────────────────────────────────────
PAYSTACK_SECRET_KEY=
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=
# Optional: Paystack plan code for recurring Pro subscriptions
# PAYSTACK_PRO_PLAN_CODE=

# ── Google OAuth (YouTube integration) ────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── TikTok OAuth ──────────────────────────────────────────────────────────────
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=
FROM_EMAIL=

# ── Notion ────────────────────────────────────────────────────────────────────
NOTION_API_KEY=

# ── Cron protection ───────────────────────────────────────────────────────────
CRON_SECRET=
